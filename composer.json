{
    "name": "form-builder/form-schema-filament",
    "description": "Filament plugin/SDK for rendering Form Schema v1 dynamic forms.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Orpheus",
            "homepage": "https://github.com/opheus2"
        }
    ],
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:opheus2/form-schema-validator.git"
        }
    ],
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0",
        "illuminate/support": "^12.0",
        "form-builder/form-schema-validator": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "FormSchema\\Filament\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FormSchema\\Filament\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "FormSchema\\Filament\\FormSchemaFilamentServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
